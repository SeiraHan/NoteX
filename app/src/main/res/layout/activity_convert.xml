<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0D0D"
    android:fitsSystemWindows="true">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#0D0D0D">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/topAppBar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="AI Studio"
            app:titleTextColor="#FFFFFF" />

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="24dp"
                app:cardBackgroundColor="#1A1A1A"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Convert Note Content"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:textSize="20sp"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Pick a note and choose a transformation."
                        android:textColor="#AAAAAA"
                        android:textSize="14sp"
                        android:layout_marginBottom="24dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSelectNote"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:text="Select Note"
                        android:textAllCaps="false"
                        app:cornerRadius="16dp"
                        app:backgroundTint="#1A1A1A"
                        android:textColor="#FFFFFF"
                        app:strokeColor="#333333"
                        app:strokeWidth="1dp"
                        android:layout_marginBottom="24dp"
                        app:icon="@drawable/ic_folder"
                        app:iconGravity="textStart"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Choose Action"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:layout_marginBottom="12dp"/>

                    <GridLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:columnCount="2"
                        android:rowCount="2"
                        android:layout_marginBottom="32dp">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnSummarize"
                            android:layout_width="0dp"
                            android:layout_height="100dp"
                            android:layout_columnWeight="1"
                            android:layout_margin="6dp"
                            android:text="📚\nSummarize"
                            android:textAllCaps="false"
                            android:textSize="14sp"
                            android:lineSpacingExtra="4dp"
                            app:cornerRadius="20dp"
                            app:backgroundTint="#0F2196F3"
                            android:textColor="#FFFFFF"
                            app:strokeColor="@color/primary_blue"
                            app:strokeWidth="2dp"/>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnQuiz"
                            android:layout_width="0dp"
                            android:layout_height="100dp"
                            android:layout_columnWeight="1"
                            android:layout_margin="6dp"
                            android:text="🧠\nMake Quiz"
                            android:textAllCaps="false"
                            android:textSize="14sp"
                            android:lineSpacingExtra="4dp"
                            app:cornerRadius="20dp"
                            app:backgroundTint="#0F4CAF50"
                            android:textColor="#FFFFFF"
                            app:strokeColor="@color/accent_green"
                            app:strokeWidth="2dp"/>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnFlashcards"
                            android:layout_width="0dp"
                            android:layout_height="100dp"
                            android:layout_columnWeight="1"
                            android:layout_margin="6dp"
                            android:text="🎯\nFlashcards"
                            android:textAllCaps="false"
                            android:textSize="14sp"
                            android:lineSpacingExtra="4dp"
                            app:cornerRadius="20dp"
                            app:backgroundTint="#0F9C27B0"
                            android:textColor="#FFFFFF"
                            app:strokeColor="@color/accent_purple"
                            app:strokeWidth="2dp"/>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnInDepth"
                            android:layout_width="0dp"
                            android:layout_height="100dp"
                            android:layout_columnWeight="1"
                            android:layout_margin="6dp"
                            android:text="🌍\nIn-Depth"
                            android:textAllCaps="false"
                            android:textSize="14sp"
                            android:lineSpacingExtra="4dp"
                            app:cornerRadius="20dp"
                            app:backgroundTint="#0FFF9800"
                            android:textColor="#FFFFFF"
                            app:strokeColor="@color/accent_orange"
                            app:strokeWidth="2dp"/>

                    </GridLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/statusCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="24dp"
                app:cardBackgroundColor="#1A1A1A"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:gravity="center">

                    <com.google.android.material.progressindicator.CircularProgressIndicator
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:indeterminate="true"
                        android:layout_marginBottom="16dp"
                        app:indicatorColor="#2196F3"/>

                    <TextView
                        android:id="@+id/tvStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="AI Studio is thinking..."
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>