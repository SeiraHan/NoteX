<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.NoteX" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowBackground">?attr/colorSurface</item>
        <item name="colorPrimary">#2196F3</item>
    </style>

    <style name="Theme.NoteX" parent="Base.Theme.NoteX" />

    <!-- Specific style for the cards to follow theme -->
    <style name="NoteCardStyle" parent="Widget.Material3.CardView.Filled">
        <item name="cardBackgroundColor">?attr/colorSurfaceVariant</item>
    </style>

    <style name="NeonTitleTextAppearance" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:fontFamily">sans-serif-condensed</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">24sp</item>
    </style>
</resources>